/// @description Project-wide enums and macros.

enum PROJECTILE_TYPE
{
	DAMAGE,
	CORRUPTION,
	SUMMON,
	RALLY
}

enum FOCUS_WINDOW
{
	NOONE,
	TARGET_SELECTION,
	PAUSE_MENU,
	SETTINGS,
	CULTIST_DEMON_SELECTION,
	CULTIST_LEVEL_UP
}

enum RESOURCES
{
	FLESH,
	SOULS,
	IRON,
	COUNT
}

enum UNIT_FACTION
{
	NOONE,
	FRIENDLY,
	ENEMY
}

enum DAY_PHASE
{
	DAY,
	NIGHT
}

enum CULTIST_STAT
{
	BODY,
	SPIRIT,
	FERVOR,
	COUNT
}

enum DEMON_TYPE
{
	NONE,
	IMP,
	WARLOCK,
	BRUTE
}

enum DEMON_ABILITY
{
	NONE,
	IMP_FRENZY,
	IMP_BLOOD_RAGE,
	IMP_CANNON_ECHO,
	WARLOCK_CURSE,
	WARLOCK_SUMMON_SKELETON,
	BRUTE_POISON_AURA,
	BRUTE_MEGA_STRIKE
}

