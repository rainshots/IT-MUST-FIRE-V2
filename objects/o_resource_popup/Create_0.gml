// Popup lifetime and fade settings.
life_time = 1.35 * room_speed;
life_timer = 0;
start_alpha = 1;
current_alpha = start_alpha;

// Popup movement settings.
move_speed_y = -0.45;

// Popup text values are set by resource_popup_create after creation.
popup_text = "";
popup_color = c_white;

// Popup visual settings.
background_color = COLOR_HUD_BACKGROUND;
background_padding_x = 8;
background_padding_y = 4;
background_alpha = 0.78;
text_offset_y = -18;
